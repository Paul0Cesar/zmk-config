 *
 * =====================================================================
 * Sofle v2 Wireless - Keymap otimizado pra Android nativo + KMP no macOS
 * =====================================================================
 *
 * Design pensado pra Kotlin: multi-char tokens (->, ?:, ?., ::, ==) viram
 * teclas únicas; pares de delimitadores em colunas adjacentes pra rolagem
 * natural do dedo; macros do Android Studio na navigation layer.
 *
 * --- LAYERS ---
 *
 * Layer 0 (BASE)    QWERTY puro. Polegares: Esc Tab Cmd Space Lower
 *                                            Raise Enter Bksp Alt Del
 * Layer 1 (LOWER)   Navegação + edição + F-keys + macros Android Studio
 * Layer 2 (RAISE)   Símbolos + números otimizados pra Kotlin
 * Layer 3 (ADJUST)  BT, RGB, ext_power (acessada via Lower+Raise)
 *
 * --- TECLAS-CHAVE NA SYMBOL LAYER (RAISE) ---
 *
 * Mão esquerda home row (multi-char Kotlin tokens):
 *     A=?.   S=?:   D=::   F=->   G==>
 *
 * Mão direita home row (delimitadores em pares):
 *     H=_   J=(   K=)   L={   ;=}   '="
 *
 * --- ENCODERS POR LAYER ---
 *
 * Default: Volume UP/DN     | Page UP/DN
 * Lower:   Word →/←         | Line ↓/↑       (navegação fina)
 * Raise:   Redo/Undo        | Next/Prev tab   (refactor + nav editor)
 *
 * --- MACROS DEFINIDAS ---
 *
 * Android Studio (na layer LOWER, F-row):
 *   AS_RUN  AS_BUILD  AS_STOP  AS_FIND  AS_FMT  AS_DEBUG
 *
 * Kotlin tokens (na layer RAISE, mão esquerda):
 *   K_SAFE (?.)  K_ELVIS (?:)  K_REF (::)  K_ARROW (->)  K_FAT (=>)
 *
 * Combinar com sofle.conf ajustado pra estabilidade BT com AVD rodando.
 * =====================================================================
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/rgb.h>

#define BASE   0
#define LOWER  1
#define RAISE  2
#define ADJUST 3

/ {
    // ADJUST layer ativa quando LOWER + RAISE são pressionados juntos
    conditional_layers {
        compatible = "zmk,conditional-layers";

        adjust_layer {
            if-layers = <LOWER RAISE>;
            then-layer = <ADJUST>;
        };
    };

    // ============================================================
    // MACROS
    // ============================================================
    macros {

        // --- Kotlin multi-char tokens ---

        K_SAFE: kotlin_safe_call {
            // ?. (safe call operator)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp QMARK &kp DOT>;
        };

        K_ELVIS: kotlin_elvis {
            // ?: (elvis operator)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp QMARK &kp COLON>;
        };

        K_REF: kotlin_member_ref {
            // :: (member reference)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp COLON &kp COLON>;
        };

        K_ARROW: kotlin_arrow {
            // -> (lambda, when, function type)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp MINUS &kp GT>;
        };

        K_FAT: kotlin_fat_arrow {
            // => (raro em Kotlin mas útil em outras stacks como JS/Dart)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp EQUAL &kp GT>;
        };

        K_EQ: kotlin_equal_equal {
            // == (comparação)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp EQUAL &kp EQUAL>;
        };

        K_NEQ: kotlin_not_equal {
            // != (não igual)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp EXCL &kp EQUAL>;
        };

        K_AND: kotlin_and {
            // && (and lógico)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp AMPS &kp AMPS>;
        };

        K_OR: kotlin_or {
            // || (or lógico)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp PIPE &kp PIPE>;
        };

        // --- Android Studio shortcuts (macOS) ---

        AS_RUN: as_run_app {
            // Cmd+R - Run app
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp LG(R)>;
        };

        AS_BUILD: as_build_project {
            // Cmd+F9 - Build project
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp LG(F9)>;
        };

        AS_STOP: as_stop {
            // Cmd+F2 - Stop running app
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp LG(F2)>;
        };

        AS_FIND: as_find_in_files {
            // Cmd+Shift+F - Find in files
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp LS(LG(F))>;
        };

        AS_FMT: as_format_code {
            // Cmd+Option+L - Reformat code
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp LA(LG(L))>;
        };

        AS_DEBUG: as_debug {
            // Cmd+D - Debug app (atenção: padrão é Ctrl+D em algumas configs;
            // ajustar se seu keymap do AS for diferente)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp LG(D)>;
        };

        AS_FIND_CLASS: as_find_class {
            // Cmd+O - Navigate to class
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp LG(O)>;
        };

        AS_FIND_FILE: as_find_file {
            // Cmd+Shift+O - Navigate to file
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <5>;
            tap-ms = <5>;
            bindings = <&kp LS(LG(O))>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ============================================================
        // LAYER 0 — DEFAULT (QWERTY base)
        // ============================================================
        default_layer {
            display-name = "default";

            // ---------------------------------------------------------------------------------------------------------------
            // |  ESC  |  1  |  2   |  3   |  4    |   5   |                          |   6   |  7    |  8    |  9  |  0  | BKSP  |
            // |  TAB  |  Q  |  W   |  E   |  R    |   T   |                          |   Y   |  U    |  I    |  O  |  P  |   \   |
            // |  CTRL |  A  |  S   |  D   |  F    |   G   |                          |   H   |  J    |  K    |  L  |  ;  |   '   |
            // | SHIFT |  Z  |  X   |  C   |  V    |   B   |   MUTE   |  |   ----     |   N   |  M    |  ,    |  .  |  /  | SHIFT |
            //               | ESC  | TAB  |  CMD  | SPACE |  LOWER   |  |   RAISE    | ENTER | BKSP  | RALT  | DEL |
            // Encoders:                                          [ VOL UP/DN ]    [ PG UP/DN ]

            bindings = <
&kp ESC           &kp N1  &kp N2   &kp N3   &kp N4    &kp N5                                  &kp N6     &kp N7         &kp N8     &kp N9    &kp N0    &kp BACKSPACE
&kp TAB           &kp Q   &kp W    &kp E    &kp R     &kp T                                   &kp Y      &kp U          &kp I      &kp O     &kp P     &kp BACKSLASH
&kp LEFT_CONTROL  &kp A   &kp S    &kp D    &kp F     &kp G                                   &kp H      &kp J          &kp K      &kp L     &kp SEMI  &kp SQT
&kp LSHFT         &kp Z   &kp X    &kp C    &kp V     &kp B      &kp C_MUTE     &none         &kp N      &kp M          &kp COMMA  &kp DOT   &kp FSLH  &kp RSHFT
                          &kp ESC  &kp TAB  &kp LGUI  &kp SPACE  &mo LOWER      &mo RAISE     &kp ENTER  &kp BACKSPACE  &kp RALT   &kp DEL
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp PG_UP PG_DN>;
        };

        // ============================================================
        // LAYER 1 — LOWER (Navegação + Android Studio + F-keys)
        // ============================================================
        // Filosofia: edição rápida de código. Setas em HJKL estilo vim,
        // word/line nav, undo/redo/cut/copy/paste, e os 8 atalhos mais
        // usados do Android Studio como teclas únicas.
        // ============================================================
        lower_layer {
            display-name = "lower";

            // ---------------------------------------------------------------------------------------------------------------
            // | ESC   | F1   | F2    | F3    | F4    | F5    |                          | F6    |       |   ↑   |       | F10   | F11   |
            // | RUN   | BUILD| STOP  | FIND  | FMT   | DEBUG |                          | HOME  |   ←   |   ↓   |   →   | END   | F12   |
            // | CTRL  | CMD  | OPT   | CTRL  | SHIFT |   ⌘O  |                          | PG_UP | WORD← | LINE↓ | WORD→ | DEL   | INS   |
            // | SHIFT | UNDO | CUT   | COPY  | PASTE | REDO  |  -----   |  |   ----     | PG_DN | TAB←  | LINE↑ | TAB→  | CAPS  | SHIFT |
            //                | ESC  | TAB    |  CMD   | SPACE |  LOWER  |  |   RAISE    | ENTER | BKSP  | RALT  | DEL   |
            // Encoders:                                            [ Word →/← ]    [ Line ↓/↑ ]

            bindings = <
&kp ESC    &kp F1     &kp F2     &kp F3     &kp F4     &kp F5                                  &kp F6      &trans         &kp UP        &trans         &kp F10   &kp F11
&AS_RUN    &AS_BUILD  &AS_STOP   &AS_FIND   &AS_FMT    &AS_DEBUG                               &kp HOME    &kp LEFT       &kp DOWN      &kp RIGHT      &kp END   &kp F12
&kp LCTRL  &kp LGUI   &kp LALT   &kp LCTRL  &kp LSHFT  &AS_FIND_CLASS                          &kp PG_UP   &kp LA(LEFT)   &kp LG(DOWN)  &kp LA(RIGHT)  &kp DEL   &kp INS
&kp LSHFT  &kp LG(Z)  &kp LG(X)  &kp LG(C)  &kp LG(V)  &kp LS(LG(Z))  &trans         &trans    &kp PG_DN   &kp LG(LBKT)   &kp LG(UP)    &kp LG(RBKT)   &kp CLCK  &kp RSHFT
                      &trans     &trans     &trans     &trans         &trans         &trans    &trans      &trans         &trans        &trans
            >;

            // Encoder esquerdo: navegar palavras (Option+→/←)
            // Encoder direito: linha pra baixo/cima (mover por linhas no editor)
            sensor-bindings = <&inc_dec_kp LA(RIGHT) LA(LEFT) &inc_dec_kp DOWN UP>;
        };

        // ============================================================
        // LAYER 2 — RAISE (Símbolos + Números — otimizado pra Kotlin)
        // ============================================================
        // Filosofia: tudo que você bate em código fica aqui. Multi-char
        // Kotlin tokens na home row da mão esquerda. Pares de delimitadores
        // em colunas adjacentes da mão direita. Números na home row da
        // mão direita pra digitação fluida.
        // ============================================================
        raise_layer {
            display-name = "raise";

            // ---------------------------------------------------------------------------------------------------------------
            // |   ~   |  !   |  @   |  #   |  $   |  %   |                          |   ^   |  &   |  *   |  -   |  +   |   `   |
            // |   |   |  1   |  2   |  3   |  4   |  5   |                          |   6   |  7   |  8   |  9   |  0   |   /   |
            // |       |  ?.  |  ?:  |  ::  |  ->  |  =>  |                          |   _   |  (   |  )   |  {   |  }   |   "   |
            // | SHIFT |  ==  |  !=  |  &&  |  ||  |  =   |  -----   |  |   ----     |   &   |  [   |  ]   |  <   |  >   | SHIFT |
            //                | ESC  | TAB  | CMD  | SPACE| LOWER    |  |   RAISE    | ENTER | BKSP | RALT | DEL  |
            // Encoders:                                            [ Redo / Undo ]    [ Next tab / Prev tab ]

            bindings = <
&kp TILDE  &kp EXCL  &kp AT     &kp HASH  &kp DLLR   &kp PRCNT                                 &kp CARET  &kp AMPS    &kp ASTRK   &kp MINUS    &kp PLUS    &kp GRAVE
&kp PIPE   &kp N1    &kp N2     &kp N3    &kp N4     &kp N5                                    &kp N6     &kp N7      &kp N8      &kp N9       &kp N0      &kp FSLH
&trans     &K_SAFE   &K_ELVIS   &K_REF    &K_ARROW   &K_FAT                                    &kp UNDER  &kp LPAR    &kp RPAR    &kp LBRC     &kp RBRC    &kp DQT
&kp LSHFT  &K_EQ     &K_NEQ     &K_AND    &K_OR      &kp EQUAL  &trans         &trans          &kp AMPS   &kp LBKT    &kp RBKT    &kp LT       &kp GT      &kp RSHFT
                     &trans     &trans    &trans     &trans     &trans         &trans          &trans     &trans      &trans      &trans
            >;

            // Encoder esquerdo: Redo (CW: Cmd+Shift+Z) / Undo (CCW: Cmd+Z)
            // Encoder direito: Próxima/Anterior aba (Cmd+Shift+] / Cmd+Shift+[)
            sensor-bindings = <&inc_dec_kp LS(LG(Z)) LG(Z) &inc_dec_kp LS(LG(RBKT)) LS(LG(LBKT))>;
        };

        // ============================================================
        // LAYER 3 — ADJUST (BT, RGB, system)
        // Ativada com LOWER + RAISE simultâneos
        // ============================================================
        adjust_layer {
            display-name = "adjust";

            // ---------------------------------------------------------------------------------------------------------------
            // | BT_CLR_ALL |  BT1   |  BT2   |  BT3    |  BT4    |  BT5    |                          |       |      |      |      |      |       |
            // |  EXT_PWR   | HUE-   | HUE+   |  SAT-   |  SAT+   |  EFFECT |                          |       |      |      |      |      |       |
            // |            | BRI-   | BRI+   |         |         |         |                          |       |      |      |      |      |       |
            // |            |        |        |         |         |         |  RGB_TOG |  |   ----     |       |      |      |      |      |       |

            bindings = <
&bt BT_CLR_ALL     &bt BT_SEL 0     &bt BT_SEL 1     &bt BT_SEL 2     &bt BT_SEL 3     &bt BT_SEL 4                                       &none  &none  &none  &none  &none  &none
&ext_power EP_TOG  &rgb_ug RGB_HUD  &rgb_ug RGB_HUI  &rgb_ug RGB_SAD  &rgb_ug RGB_SAI  &rgb_ug RGB_EFF                                    &none  &none  &none  &none  &none  &none
&none              &rgb_ug RGB_BRD  &rgb_ug RGB_BRI  &none            &none            &none                                              &none  &none  &none  &none  &none  &none
&none              &none            &none            &none            &none            &none            &rgb_ug RGB_TOG    &none         &none  &none  &none  &none  &none  &none
                                    &none            &none            &none            &none            &none              &none         &none  &none  &none  &none
            >;
        };
    };
};
